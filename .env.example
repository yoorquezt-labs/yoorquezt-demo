# YoorQuezt Testnet Demo
# Copy to .env.testnet and fill in your values
#
# Required: Sepolia RPC + test wallet private key
# Optional: L2 RPCs default to public endpoints

# ─── Required ──────────────────────────────────
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
SIGNER_PRIVATE_KEY=YOUR_TEST_PRIVATE_KEY_HERE
MEV_API_TOKEN=demo-token
MESH_SHARED_KEY=yoorqueztdemomeshsharedkey123456

# ─── Optional (defaults to public RPCs) ────────
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# OP_SEPOLIA_RPC_URL=https://sepolia.optimism.io
# SOLANA_RPC_URL=https://api.devnet.solana.com

# ─── Relay (defaults to Flashbots Sepolia) ─────
# FLASHBOTS_RELAY_URL=https://relay-sepolia.flashbots.net
# MEV_SHARE_SSE_URL=https://mev-share-sepolia.flashbots.net
# MEV_SHARE_RPC_URL=https://relay-sepolia.flashbots.net
