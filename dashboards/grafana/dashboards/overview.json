{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Platform Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "title": "Mesh — Transactions Gossiped",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(mesh_gossip_messages_total[1m])",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Mesh — Connected Peers",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "mesh_connected_peers",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "MEV — Bundles Submitted",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "rate(mev_bundles_submitted_total[1m])",
          "legendFormat": "bundles/s"
        }
      ]
    },
    {
      "title": "MEV — Auction Profit (ETH)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "mev_auction_profit_eth_total",
          "legendFormat": "profit"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "eth" }
      }
    },
    {
      "title": "OFA — Rebates Distributed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "ofa_rebates_total",
          "legendFormat": "rebates"
        }
      ]
    },
    {
      "title": "Mesh — Gossip Latency (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(mesh_gossip_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.50, rate(mesh_gossip_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "MEV — Strategy Performance",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(mev_strategy_executions_total[5m])",
          "legendFormat": "{{strategy}}"
        }
      ]
    }
  ],
  "refresh": "5s",
